git_url(ENV["MATCH_GIT_URL"])
storage_mode("git")
type("appstore")
app_identifier("com.hugovinicius.roof")

# Use App Store Connect API Key instead of Apple ID + password
# This avoids the "Access Forbidden" error from Apple blocking password auth
api_key_path(ENV["APP_STORE_CONNECT_API_KEY_PATH"]) if ENV["APP_STORE_CONNECT_API_KEY_PATH"]
